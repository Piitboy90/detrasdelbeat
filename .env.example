# Plantilla de variables de entorno.
# Copia este archivo a .env.local y rellena los valores.
# En Railway, configura estas mismas vars en Settings -> Variables.
#
# IMPORTANTE: en Vite, las vars VITE_* se incrustan en el bundle durante el
# 'npm run build'. Hay que tenerlas definidas ANTES de buildear, no despues.

# Credenciales del proyecto Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Feature flag: fecha de lanzamiento de la seccion Requests
VITE_REQUESTS_LAUNCH_AT=2026-03-01T12:00:00+01:00
